# .graphifyignore — дополнительные исключения для graphify.
# Синтаксис как у .gitignore; объединяется с .gitignore (эти правила побеждают).
# Цель — гарантировать, что секреты и бинарные медиа не попадут в граф/семантический проход.

# --- Секреты (подстраховка; .gitignore уже прикрывает .env*/*.pem) ---
.env*
*.pem
*.key
*.p12
*.pfx
*secret*
*credential*

# --- Зависимости и артефакты сборки ---
node_modules/
.next/
out/
graphify-out/

# --- Бинарные медиа: пропускаем семантический проход по ассетам ---
public/
*.png
*.jpg
*.jpeg
*.webp
*.avif
*.gif
*.ico
*.pdf
*.mp4
*.mov
